<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#28FFFFFF"
    android:backgroundTint="#FFFFFF"
    android:orientation="horizontal">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/andika_new_basic"
        android:text="Audios"
        android:textAlignment="center"
        android:textColor="#5779CC"
        android:textSize="34sp" />

    <TextView
        android:layout_width="221dp"
        android:layout_height="30dp"
        android:layout_x="93dp"
        android:layout_y="101dp"
        android:text="Volumen"
        android:textAlignment="center"
        android:textColor="#1C2D4C"
        android:textSize="16sp" />

    <ImageView
        android:layout_width="60dp"
        android:layout_height="63dp"
        android:layout_x="169dp"
        android:layout_y="160dp"
        android:src="@drawable/volume" />

    <Button
        android:id="@+id/button_volume1"
        android:layout_width="95dp"
        android:layout_height="wrap_content"
        android:layout_x="38dp"
        android:layout_y="160dp"
        android:backgroundTint="#7AA1CC"
        android:text="Bajar volumen"
        android:textColor="#FFFFFF"
        android:textSize="10sp" />

    <Button
        android:id="@+id/button_volume2"
        android:layout_width="95dp"
        android:layout_height="wrap_content"
        android:layout_x="273dp"
        android:layout_y="160dp"
        android:backgroundTint="#7AA1CC"
        android:text="Subir volumen"
        android:textColor="#FBFBFB"
        android:textSize="10sp" />

    <Button
        android:id="@+id/button_ini_a5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_x="5dp"
        android:layout_y="654dp"
        android:backgroundTint="#689EC6"
        android:text="Iniciar / Pausar"
        android:textColor="#FFFEFE" />

    <Button
        android:id="@+id/button_a5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_x="138dp"
        android:layout_y="305dp"
        android:backgroundTint="#2C65A3"
        android:text="Audio A5"
        android:textColor="#FBFBFB" />

    <Button
        android:id="@+id/button_a6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/button_a5"
        android:layout_alignParentStart="true"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp"
        android:layout_x="138dp"
        android:layout_y="377dp"
        android:backgroundTint="#2C65A3"
        android:textColor="#FBFBFB"
        android:text="Audio A6" />

    <Button
        android:id="@+id/button_b0"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/button_a5"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="32dp"
        android:layout_x="138dp"
        android:layout_y="454dp"
        android:backgroundTint="#2C65A3"
        android:textColor="#FBFBFB"
        android:text="Audio B0" />


</AbsoluteLayout>
